<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="Pedra, Papel e Tesoura"
            android:textColor="#1A1A2E"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Placar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jogador"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvScorePlayer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Computador"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tvScoreComputer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Botões de escolha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escolha sua jogada:"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="4dp">

                <Button
                    android:id="@+id/btnPedra"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:text="✊"
                    android:textSize="32sp"
                    android:backgroundTint="#E3F2FD"
                    android:textColor="#1565C0"
                    android:elevation="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pedra"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <Button
                    android:id="@+id/btnPapel"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:text="✋"
                    android:textSize="32sp"
                    android:backgroundTint="#E8F5E9"
                    android:textColor="#2E7D32"
                    android:elevation="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Papel"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="4dp">

                <Button
                    android:id="@+id/btnTesoura"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:text="✌️"
                    android:textSize="32sp"
                    android:backgroundTint="#FFF3E0"
                    android:textColor="#E65100"
                    android:elevation="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tesoura"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Jogada do computador -->
        <TextView
            android:id="@+id/tvComputerChoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aguardando jogada..."
            android:textSize="16sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp"/>

        <!-- Resultado -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="24dp"/>

        <!-- Botões de ação -->
        <Button
            android:id="@+id/btnNovaJogada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nova Jogada"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnFinalizarJogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finalizar Jogo"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="12dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>